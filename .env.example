SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

EMBEDDING_PROVIDER=huggingface
EMBEDDING_API_KEY=your-hugging-face-token
EMBEDDING_BASE_URL=https://router.huggingface.co/hf-inference/models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# For OpenAI embeddings instead, use:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=your-openai-api-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

CHAT_API_KEY=your-openai-compatible-key
CHAT_BASE_URL=https://api.groq.com/openai/v1
CHAT_MODEL=llama-3.3-70b-versatile
CHAT_APP_URL=
CHAT_APP_NAME=Tartarus Guide
FACT_EXTRACTION_MODEL=qwen/qwen3-32b
# Bulk extraction uses a separate model so the 70B chat quota stays available
# for user-facing answers. Scout and CHAT_MODEL are automatic fallbacks.
FACT_EXTRACTION_DELAY_MS=15000
# For Groq, use:
# CHAT_API_KEY=your-groq-api-key
# CHAT_BASE_URL=https://api.groq.com/openai/v1
# CHAT_MODEL=llama-3.3-70b-versatile
# For OpenRouter, use:
# CHAT_API_KEY=your-openrouter-api-key
# CHAT_BASE_URL=https://openrouter.ai/api/v1
# CHAT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

INGEST_USER_AGENT=TartarusGuideRAG/0.1 (+local development; contact@example.com)
INGEST_DELAY_MS=2500
RAW_CACHE_DIR=.cache/raw-pages
# Optional: pin the community fusion dataset to a reviewed Git revision.
FUSION_DATA_REVISION=568aaf748aa3d83e47c0ff770c82f74d85273a8b

# Optional: force mock answers even when credentials exist.
USE_MOCK_CHAT=false

# Security controls for the public chat route.
ALLOWED_ORIGINS=https://your-production-domain.example
RATE_LIMIT_SALT=replace-with-a-long-random-value
CHAT_RATE_LIMIT_PER_MINUTE=20
CHAT_RATE_LIMIT_PER_DAY=250
# Keep false in public deployments. Debug responses expose retrieval diagnostics.
ALLOW_CHAT_DEBUG=false

# Optional: call a separate deployed RAG service before direct Supabase retrieval.
RAG_CHAT_ENDPOINT=
