SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

EMBEDDING_PROVIDER=huggingface
EMBEDDING_API_KEY=your-hugging-face-token
EMBEDDING_BASE_URL=https://router.huggingface.co/hf-inference/models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# For OpenAI embeddings instead, use:
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=your-openai-api-key
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

CHAT_API_KEY=your-openai-compatible-key
CHAT_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=llama-3.3-70b-versatile
# For Groq, use:
# CHAT_API_KEY=your-groq-api-key
# CHAT_BASE_URL=https://api.groq.com/openai/v1
# CHAT_MODEL=llama-3.3-70b-versatile

INGEST_USER_AGENT=TartarusGuideRAG/0.1 (+local development; contact@example.com)
INGEST_DELAY_MS=2500
RAW_CACHE_DIR=.cache/raw-pages

# Optional: force mock answers even when credentials exist.
USE_MOCK_CHAT=false

# Optional: call a separate deployed RAG service before direct Supabase retrieval.
RAG_CHAT_ENDPOINT=
