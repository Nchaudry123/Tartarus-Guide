{
  "name": "tartarus-guide-rag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "ingest": "tsx src/ingest/runIngestion.ts",
    "ingest:targeted": "tsx src/ingest/runIngestion.ts --target-gaps",
    "ingest:lite": "node scripts/ingest-lite.mjs",
    "ingest:facts": "tsx src/ingest/backfillFacts.ts",
    "ingest:facts:deterministic": "tsx src/ingest/backfillFacts.ts --deterministic-only",
    "test:facts": "tsx --test src/ingest/extractFacts.test.ts",
    "ingest:fusion": "tsx src/ingest/importFusionTool.ts",
    "ingest:audit": "tsx src/ingest/auditIndex.ts",
    "ingest:coverage": "tsx src/ingest/coverageReport.ts",
    "ingest:gaps": "tsx src/ingest/analyzeCoverage.ts",
    "ingest:cleanup": "tsx src/ingest/cleanupInvalidFacts.ts",
    "eval:accuracy": "tsx src/eval/runAccuracyEval.ts",
    "eval:gate": "tsx src/eval/runAccuracyEval.ts --direct --origin=user_transcript --fail-under=0.85 --exact-fail-under=0.85 --hallucination-fail-under=0.95 --delay-ms=250",
    "eval:validate": "tsx src/eval/runAccuracyEval.ts --validate-only",
    "eval:retrieval": "tsx src/eval/testRetrievalHeuristics.ts",
    "eval:grounding": "tsx src/eval/testGroundingSafeguards.ts && tsx --test src/quality/relationships.test.ts src/quality/exactFacts.test.ts",
    "eval:spoilers": "tsx src/eval/testSpoilerControls.ts",
    "test:security": "tsx --test src/security/chatSecurity.test.ts",
    "test:cache": "tsx --test src/cache/ttlCache.test.ts",
    "ask": "tsx src/ask.ts",
    "typecheck": "tsc --noEmit",
    "vercel-build": "npm run eval:validate && npm run test:facts && npm run eval:retrieval && npm run eval:grounding && npm run eval:spoilers && npm run test:security && npm run test:cache && npm run typecheck && ALLOW_CHAT_DEBUG=true CHAT_RATE_LIMIT_PER_MINUTE=500 CHAT_RATE_LIMIT_PER_DAY=1000 npm run eval:gate && next build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "framer-motion": "^11.11.10",
    "lucide-react": "^0.468.0",
    "next": "16.2.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "robots-parser": "^3.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "8.5.15",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
